# ============================================================
# Environment Variables — copy to .env and fill in values
# NEVER commit .env to source control
# ============================================================

# Eureka Basic Auth credentials
EUREKA_USERNAME=eureka-admin
EUREKA_PASSWORD=changeme-in-production

# Hostname of THIS Eureka node (used for peer replication)
EUREKA_HOSTNAME=eureka-1.internal.example.com

# Peer Eureka node URLs (comma-separated)
# Format: http://user:pass@hostname:port/eureka/
EUREKA_PEER_URLS=http://eureka-admin:changeme@eureka-2.internal.example.com:8761/eureka/

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=prod

# Availability zone tag (metadata)
AVAILABILITY_ZONE=us-east-1a
AWS_REGION=us-east-1
